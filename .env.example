# NEØ:One - Environment Variables Example
# Copie este arquivo para .env e preencha com suas chaves reais


# Runtime obrigatório
# LLM principal e segredo da sessão soberana.
ASI1_API_KEY=sua_chave_aqui
ASI1_MODEL=asi1
SESSION_SIGNING_SECRET=gere_um_segredo_aleatorio_com_32_ou_mais_caracteres

# Redis — memória e rate limit distribuído
# Produção atual: Redis Cloud externo via endpoint público/TCP.
# Formato: redis://default:password@host:port
# Fallback temporário: Redis Railway, se reativado explicitamente no deploy.
# Hosts *.railway.internal só resolvem dentro da rede Railway.
REDIS_URL=redis://localhost:xxxx
# A senha, quando exigida, faz parte de REDIS_URL.
# O runtime não lê uma variável REDIS_PASSWORD separada.

# Dashboard operacional /admin
# Obrigatórias apenas para habilitar o dashboard protegido por HTTP Basic Auth.
DASHBOARD_USER=seu_usuario
DASHBOARD_PASSWORD=uma_senha_longa_e_unica

# Postgres HA — Captura de Leads (Railway via PgBouncer)
# Formato Railway: postgresql://postgres:password@host:port/railway
DATABASE_URL=postgresql://localhost:5432/neoflowoff
# Modo SSL do banco ("require" para externos com SSL, "false" para interno HA Railway)
DB_SSL_MODE=false

# Email Handoff Notifications (Resend API)
# O sistema degrada sem envio de emails quando RESEND_API_KEY estiver ausente.
RESEND_API_KEY=sua_chave_do_resend_aqui
RESEND_FROM=seu_email@dominio.com
RESEND_TO=seu_email@dominio.com

# Meta Pixel & Conversions API (CAPI) — Tracking & Inteligência Comercial
# PUBLIC_ prefix obrigatório para variáveis expostas ao cliente/navegador via Astro.
# NEOPixel (Dataset ID no Meta Events Manager onde os eventos são gravados):
PUBLIC_META_PIXEL_ID=seu_meta_pixel_id_aqui

# O Pixel só deve carregar após consentimento explícito do visitante.
# O estado de consentimento não é configurado por variável de ambiente.

# Token server-side preferencial para a Conversions API.
META_CAPI_TOKEN=seu_token_de_acesso_gerado_no_app_aqui
# Alias legado aceito pelo runtime quando META_CAPI_TOKEN estiver ausente:
# META_ACCESS_TOKEN=seu_token_de_acesso_gerado_no_app_aqui
# Use somente durante validação no Meta Events Manager; remova em produção normal.
META_TEST_EVENT_CODE=seu_codigo_de_teste_aqui

# Observabilidade opcional
# DEBUG=true
# TEST_LOGS=true
