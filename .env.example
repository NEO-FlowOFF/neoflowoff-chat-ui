# NØX - Environment Variables Example
# Copie este arquivo para .env e preencha com suas chaves reais

# Venice AI Configuration
# Obtenha em: https://venice.ai/settings/api
VENICE_API_KEY=sua_chave_aqui
VENICE_MODEL=venice-uncensored-role-play

# Redis Configuration (Railway)
# Local: redis://default:password@host:port
# Produção (Interno): redis://default:password@redis.railway.internal:6379
REDIS_URL=redis://localhost:6379

# Security
# O domínio oficial para proteção de Origin
SITE_URL=https://chat.neoflowoff.agency
