        "url": "https://neoflowoff.agency/",
        "telephone": "+55-62-98323-1110",
        "email": "neo@neoflowoff.agency",
        "hasMap": "https://maps.app.goo.gl/WJffZwDtkTweZCn19",
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": -16.701819,
          "longitude": -49.245187
        },
        "areaServed": {
          "@type": "GeoCircle",
          "geoMidpoint": {
            "@type": "GeoCoordinates",
