  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Codystar&family=Geist+Mono:wght@300;400;500&family=Inter+Tight:wght@500;600;700&display=swap" rel="stylesheet" />

  <style is:global>
    :root {
      --bg:          #ececec;
      --bg-alt:      #dddddd;
      --surface:     rgba(255, 255, 255, 0.38) !important;
      --surface-dark:rgba(255, 255, 255, 0.22) !important;
      --hud:         rgba(255, 255, 255, 0.44) !important;
      --hud-soft:    rgba(255, 255, 255, 0.28) !important;
      --border:      rgba(22, 22, 22, 0.08) !important;
      --border-hud:  rgba(255, 255, 255, 0.42) !important;
      --glass-blur:  blur(24px) saturate(1.3) !important;
      --glass-shadow: 0 10px 26px rgba(20, 20, 20, 0.09), inset 0 1px 0.5px rgba(255, 255, 255, 0.45), inset 0 -1px 2px rgba(0, 0, 0, 0.03) !important;
      
      --neon-pink:  #ff077c;
      --neon-pink-dim: rgba(255, 7, 124, 0.15);
      --neon-glow:   rgba(255, 7, 124, 0.4);
      --neon-glow-intense: rgba(255, 7, 124, 0.6);
      --neon-green: var(--neon-pink);
      --neon-green-dim: var(--neon-pink-dim);
      --neon-green-glow: var(--neon-glow);
      --neon-green-glow-intense: var(--neon-glow-intense);
      
      --neon-pink-secondary:   #ff077c;
      --neon-pink-dim-secondary: rgba(255, 7, 124, 0.15);
      
      --text-primary:#1e1f22;
      --text-muted:  #666a73;
      --text-hud:    #1e1f22;
      --text-hud-dim:#818793;
      
      --radius-card: 24px;
      --radius-pill: 999px;
      
      --shadow-card: 0 10px 28px rgba(18, 18, 18, 0.08);
      --shadow-hud:  0 12px 34px rgba(18, 18, 18, 0.10);
      --shadow-inner: inset 0 1px 3px rgba(18,18,18,0.04);
      --glow-soft: 0 0 20px rgba(255, 7, 124, 0.1);
      
      --font-display:'Inter Tight', sans-serif;
      --font-mono:   'Geist Mono', monospace;
      --font-dot:    'Codystar', sans-serif;
      
      --safe-top:    env(safe-area-inset-top, 0px);
      --safe-bottom: env(safe-area-inset-bottom, 0px);
    }

    body.dark-mode {
      --bg: #171717;
      --bg-alt: #101010;
      --surface: rgba(255, 255, 255, 0.08);
      --surface-dark: rgba(255, 255, 255, 0.05);
      --hud: rgba(20, 20, 20, 0.64);
      --hud-soft: rgba(255, 255, 255, 0.05);
      --text-primary: #f0f0f0;
      --text-muted: #9a9a9a;
      --text-hud: #e6e6e6;
      --text-hud-dim: #ababab;
      --border: rgba(255, 255, 255, 0.14);
      --border-hud: rgba(255, 255, 255, 0.16);
      --glass-blur: blur(30px) saturate(1.18) brightness(0.92);
      --glass-shadow: 0 16px 42px rgba(6, 10, 16, 0.62), inset 0 1px 0 rgba(255, 255, 255, 0.08);
      --shadow-card: var(--glass-shadow);
      --shadow-inner: inset 0 2px 8px rgba(0, 0, 0, 0.35);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; height: 100dvh; overflow: hidden; -webkit-tap-highlight-color: transparent; }

    body {
      font-family: var(--font-mono);
      background: radial-gradient(circle at center, var(--bg) 0%, var(--bg-alt) 100%);
      background-attachment: fixed;
      color: var(--text-primary);
      display: flex;
      flex-direction: column;
      /* Safe Areas para PWA Mobile */
      padding-top: var(--safe-top);
      padding-bottom: var(--safe-bottom);
    }

    body::before {
      content: '';
      position: fixed; inset: 0;
      opacity: 0.08; pointer-events: none; z-index: 9999;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.95' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-repeat: repeat; background-size: 150px;
      mix-blend-mode: overlay;
    }
    body::after {
      content: '';
      position: fixed; inset: 0;
      opacity: 0.03; pointer-events: none; z-index: -1;
      background-image: 
        linear-gradient(rgba(0,0,0,0.1) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,0,0,0.1) 1px, transparent 1px);
      background-size: 40px 40px;
    }
    
    * { scrollbar-width: none; }
    *::-webkit-scrollbar { display: none; }

    /* MOBILE-FIRST CONTAINER — Desktop: max-width centrado */
    body {
      align-items: center;
    }

    #app-shell {
      width: 100%;
      max-width: 480px;
      height: 100%;
      height: 100dvh;
      display: flex;
      flex-direction: column;
      position: relative;
      overflow: hidden;
      /* Borda sutil nos lados em desktop */
      box-shadow: 0 0 0 1px rgba(0,0,0,0.06), 0 20px 60px rgba(0,0,0,0.08);
    }

    body.dark-mode #app-shell {
      box-shadow: 0 0 0 1px rgba(255,255,255,0.06), 0 20px 80px rgba(0,0,0,0.5);
    }
  </style>

  <!-- Filtros de Processamento Visual -->
  <svg style="position: fixed; width: 0; height: 0; pointer-events: none;">
    <filter id="chromatic-aberration">
      <feOffset in="SourceGraphic" dx="-0.4" dy="0" result="red" />
      <feOffset in="SourceGraphic" dx="0.4" dy="0" result="blue" />
      <feComponentTransfer in="red" result="red-c">
        <feFuncR type="linear" slope="1" />
        <feFuncG type="linear" slope="0" />
        <feFuncB type="linear" slope="0" />
      </feComponentTransfer>
      <feComponentTransfer in="blue" result="blue-c">
        <feFuncR type="linear" slope="0" />
        <feFuncG type="linear" slope="0" />
        <feFuncB type="linear" slope="1" />
      </feComponentTransfer>
      <feBlend in="red-c" in2="blue-c" mode="screen" result="rb" />
      <feBlend in="rb" in2="SourceGraphic" mode="screen" />
    </filter>
  </svg>
</head>
<body>
    <ClientRouter />
    <div id="app-shell">
      <slot />
    </div>
    <script is:inline>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker.register("/sw.js").catch(() => {});
        });
      }
    </script>
</body>
</html>
