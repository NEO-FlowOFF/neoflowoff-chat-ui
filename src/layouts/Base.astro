<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#111111" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="NEØ:one" />
  <title> NEØ:one — NEØ FlowOFF</title>

  <meta name="description" content="NEØ:one — Núcleo de Inteligência Soberana do Ecossistema FlowOFF. Marketing on-chain, arquitetura de agentes e infraestrutura descentralizada." />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://chat.neoflowoff.agency/" />
  <meta property="og:title" content="NEØ:one · Ecosystem Orchestrator" />
  <meta property="og:description" content="Inteligência estratégica para marketing on-chain e protocolos soberanos." />
  <meta property="og:image" content="https://res.cloudinary.com/dgyocpguk/image/upload/v1769091295/flowoff/public/icon-512.webp" />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content="https://chat.neoflowoff.agency/" />
  <meta property="twitter:title" content="NEØ:one · Ecosystem Orchestrator" />
  <meta property="twitter:description" content="Inteligência estratégica para marketing on-chain e protocolos soberanos." />
  <meta property="twitter:image" content="https://res.cloudinary.com/dgyocpguk/image/upload/v1769091295/flowoff/public/icon-512.webp" />

  <!-- Schema.org Markup -->
  <script type="application/ld+json" is:inline>
    [
      {
        "@context": "https://schema.org",
        "@type": "WebApplication",
        "name": "NEØ:one - Agente Autônomo",
        "alternateName": "NEØ FlowOFF Chat UI",
        "description": "Interface PWA do Agente NEØ:one para gestão de marketing em blockchain e tokens.",
        "url": "https://chat.neoflowoff.agency/",
        "applicationCategory": "BusinessApplication",
        "operatingSystem": "all",
        "author": {
          "@type": "Organization",
          "name": "NEØ FlowOFF",
          "url": "https://neoflowoff.agency/"
        },
        "image": "https://res.cloudinary.com/dgyocpguk/image/upload/v1769091295/flowoff/public/icon-512.webp"
      }
    ]
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Codystar&family=Geist+Mono:wght@300;400;500&family=Inter+Tight:wght@500;600;700&display=swap" rel="stylesheet" />

  <style is:global>
    :root {
      --bg:          #f2f2f2;
      --bg-alt:      #e5e5e5;
      --surface:     rgba(0, 0, 0, 0.04) !important;
      --surface-dark:rgba(0, 0, 0, 0.08) !important;
      --hud:         rgba(0, 0, 0, 0.06) !important;
      --hud-soft:    rgba(0, 0, 0, 0.02) !important;
      --border:      rgba(0, 0, 0, 0.05) !important;
      --border-hud:  rgba(255, 255, 255, 0.25) !important;
      --glass-blur:  blur(25px) saturate(1.5) !important;
      --glass-shadow: 0 4px 16px rgba(0, 0, 0, 0.03), inset 0 1px 0.5px rgba(255, 255, 255, 0.4), inset 0 -1px 2px rgba(0, 0, 0, 0.01) !important;
      
      --neon-pink:  #ff077c;
      --neon-pink-dim: rgba(255, 7, 124, 0.15);
      --neon-glow:   rgba(255, 7, 124, 0.4);
      --neon-glow-intense: rgba(255, 7, 124, 0.6);
      --neon-green: var(--neon-pink);
      --neon-green-dim: var(--neon-pink-dim);
      --neon-green-glow: var(--neon-glow);
      --neon-green-glow-intense: var(--neon-glow-intense);
      
      --neon-pink-secondary:   #ff077c;
      --neon-pink-dim-secondary: rgba(255, 7, 124, 0.15);
      
      --text-primary:#1a1c1e;
      --text-muted:  #5c6e7a;
      --text-hud:    #1a1c1e;
      --text-hud-dim:#7e8c9a;
      
      --radius-card: 24px;
      --radius-pill: 999px;
      
      --shadow-card: 0 4px 20px rgba(0, 0, 0, 0.03);
      --shadow-hud:  0 8px 32px rgba(0, 0, 0, 0.05);
      --shadow-inner: inset 0 1px 4px rgba(0,0,0,0.02);
      --glow-soft: 0 0 20px rgba(255, 7, 124, 0.1);
      
      --font-display:'Inter Tight', sans-serif;
      --font-mono:   'Geist Mono', monospace;
      --font-dot:    'Codystar', sans-serif;
      
      --safe-top:    env(safe-area-inset-top, 0px);
      --safe-bottom: env(safe-area-inset-bottom, 0px);
    }

    body.dark-mode {
      --bg: #0a0a0a;
      --bg-alt: #000000;
      --surface: rgba(255, 255, 255, 0.06);
      --surface-dark: rgba(255, 255, 255, 0.1);
      --hud: rgba(255, 255, 255, 0.05);
      --hud-soft: rgba(255, 255, 255, 0.04);
      --text-primary: #f0f0f0;
      --text-muted: #888888;
      --text-hud: #e8e8e8;
      --text-hud-dim: #9a9a9a;
      --border: rgba(255, 255, 255, 0.12);
      --border-hud: rgba(255, 255, 255, 0.1);
      --glass-blur: blur(35px) saturate(1.4) brightness(0.8);
      --glass-shadow: 0 12px 40px rgba(0, 0, 0, 0.6), inset 0 1px 0 rgba(255, 255, 255, 0.08);
      --shadow-card: var(--glass-shadow);
      --shadow-inner: inset 0 4px 12px rgba(0, 0, 0, 0.4);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; height: 100dvh; overflow: hidden; -webkit-tap-highlight-color: transparent; }

    body {
      font-family: var(--font-mono);
      background: radial-gradient(circle at center, var(--bg) 0%, var(--bg-alt) 100%);
      background-attachment: fixed;
      color: var(--text-primary);
      display: flex;
      flex-direction: column;
      /* Safe Areas para PWA Mobile */
      padding-top: var(--safe-top);
      padding-bottom: var(--safe-bottom);
    }

    body::before {
      content: '';
      position: fixed; inset: 0;
      opacity: 0.12; pointer-events: none; z-index: 9999;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.95' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-repeat: repeat; background-size: 150px;
      mix-blend-mode: overlay;
    }
    body::after {
      content: '';
      position: fixed; inset: 0;
      opacity: 0.03; pointer-events: none; z-index: -1;
      background-image: 
        linear-gradient(rgba(0,0,0,0.1) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,0,0,0.1) 1px, transparent 1px);
      background-size: 40px 40px;
    }
    
    * { scrollbar-width: none; }
    *::-webkit-scrollbar { display: none; }

    /* MOBILE-FIRST CONTAINER — Desktop: max-width centrado */
    body {
      align-items: center;
    }

    #app-shell {
      width: 100%;
      max-width: 480px;
      height: 100%;
      height: 100dvh;
      display: flex;
      flex-direction: column;
      position: relative;
      overflow: hidden;
      /* Borda sutil nos lados em desktop */
      box-shadow: 0 0 0 1px rgba(0,0,0,0.06), 0 20px 60px rgba(0,0,0,0.08);
    }

    body.dark-mode #app-shell {
      box-shadow: 0 0 0 1px rgba(255,255,255,0.06), 0 20px 80px rgba(0,0,0,0.5);
    }
  </style>

  <!-- Filtros de Processamento Visual -->
  <svg style="position: fixed; width: 0; height: 0; pointer-events: none;">
    <filter id="chromatic-aberration">
      <feOffset in="SourceGraphic" dx="-0.4" dy="0" result="red" />
      <feOffset in="SourceGraphic" dx="0.4" dy="0" result="blue" />
      <feComponentTransfer in="red" result="red-c">
        <feFuncR type="linear" slope="1" />
        <feFuncG type="linear" slope="0" />
        <feFuncB type="linear" slope="0" />
      </feComponentTransfer>
      <feComponentTransfer in="blue" result="blue-c">
        <feFuncR type="linear" slope="0" />
        <feFuncG type="linear" slope="0" />
        <feFuncB type="linear" slope="1" />
      </feComponentTransfer>
      <feBlend in="red-c" in2="blue-c" mode="screen" result="rb" />
      <feBlend in="rb" in2="SourceGraphic" mode="screen" />
    </filter>
  </svg>
</head>
<body>
    <div id="app-shell">
      <slot />
    </div>
</body>
</html>
