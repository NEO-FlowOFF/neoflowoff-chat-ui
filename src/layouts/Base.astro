  <!-- Schema.org Markup -->
  <script type="application/ld+json" is:inline>
    [
      {
        "@context": "https://schema.org",
        "@type": "WebApplication",
        "name": "NEØ:one - Agente Autônomo",
        "alternateName": "NEØ FlowOFF Chat UI",
