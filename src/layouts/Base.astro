<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
<link rel="preload" as="style" onload="this.rel='stylesheet'" href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@300;400;500&family=Inter+Tight:wght@400;500;600;700&display=swap" />
<noscript>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@300;400;500&family=Inter+Tight:wght@400;500;600;700&display=swap" />
</noscript>

  <style is:global>
    :root {
      --bg:          #f90a7a;
      --bg-alt:      #b90052;
      --surface:     rgba(255, 255, 255, 0.86) !important;
      --surface-dark:rgba(255, 255, 255, 0.72) !important;
      --hud:         rgba(146, 0, 67, 0.72) !important;
      --hud-soft:    rgba(94, 0, 44, 0.76) !important;
      --border:      rgba(73, 0, 36, 0.16) !important;
      --border-hud:  rgba(255, 255, 255, 0.42) !important;
      --glass-blur:  blur(18px) saturate(1.14) !important;
      --glass-shadow: 0 12px 32px rgba(95, 0, 46, 0.22), inset 0 1px 0.5px rgba(255, 255, 255, 0.45) !important;
      
      --neon-pink:  #ff077c;
      --neon-pink-dim: rgba(255, 7, 124, 0.15);
      --neon-glow:   rgba(255, 7, 124, 0.4);
      --neon-glow-intense: rgba(255, 7, 124, 0.6);
      --neon-orange: #ff6d00;
      --neon-orange-glow: rgba(255, 109, 0, 0.4);
      --neon-green: var(--neon-pink);
      --neon-green-dim: var(--neon-pink-dim);
      --neon-green-glow: var(--neon-glow);
      --neon-green-glow-intense: var(--neon-glow-intense);
      
      --neon-pink-secondary:   #ff077c;
      --neon-pink-dim-secondary: rgba(255, 7, 124, 0.15);
      
      --text-primary:#2a0617;
      --text-muted:  rgba(55, 4, 27, 0.64);
      --text-hud:    #2a0617;
      --text-hud-dim:rgba(55, 4, 27, 0.68);
      
      --radius-card: 24px;
      --radius-pill: 999px;
      
      --shadow-card: 0 10px 28px rgba(18, 18, 18, 0.08);
      --shadow-hud:  0 12px 34px rgba(18, 18, 18, 0.10);
      --shadow-inner: inset 0 1px 3px rgba(18,18,18,0.04);
      --glow-soft: 0 0 20px rgba(255, 7, 124, 0.1);
      
      --font-display:'Inter Tight', sans-serif;
      --font-mono:   'Geist Mono', monospace;
      
      --safe-top:    env(safe-area-inset-top, 0px);
      --safe-bottom: env(safe-area-inset-bottom, 0px);
      --radius-shell: 20px;
    }

    body.dark-mode {
      --bg: #171717;
      --bg-alt: #101010;
      --surface: rgba(14, 14, 14, 0.74);
      --surface-dark: rgba(10, 10, 10, 0.86);
      --hud: rgba(12, 12, 12, 0.78);
      --hud-soft: rgba(24, 24, 24, 0.52);
      --text-primary: #f0f0f0;
      --text-muted: #9a9a9a;
      --text-hud: #e6e6e6;
      --text-hud-dim: #ababab;
      --border: rgba(255, 255, 255, 0.09);
      --border-hud: rgba(255, 255, 255, 0.08);
      --glass-blur: blur(30px) saturate(1.18) brightness(0.92);
      --glass-shadow: 0 16px 42px rgba(6, 10, 16, 0.72), inset 0 1px 0 rgba(255, 255, 255, 0.03);
      --shadow-card: var(--glass-shadow);
      --shadow-inner: inset 0 2px 8px rgba(0, 0, 0, 0.35);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      min-height: 100%;
      overflow: hidden;
      background: #030304;
      -webkit-tap-highlight-color: transparent;
    }

    .container {
      width: 100vw;
      height: 100vh;
      max-width: 100%;
    }

    body {
      font-family: var(--font-mono);
      background: var(--bg);
      color: var(--text-primary);
      display: flex;
      flex-direction: column;
    }

    body::before {
      content: '';
      position: fixed; inset: 0;
      opacity: 0.13; pointer-events: none; z-index: 9999;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.86' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.62'/%3E%3C/svg%3E");
      background-repeat: repeat; background-size: 190px 190px;
      mix-blend-mode: soft-light;
    }
    body::after {
      content: '';
      position: fixed; inset: 0;
      opacity: 0.03; pointer-events: none; z-index: -1;
      background-image: 
        linear-gradient(rgba(0,0,0,0.1) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,0,0,0.1) 1px, transparent 1px);
      background-size: 40px 40px;
    }
    
    * { scrollbar-width: none; }
    *::-webkit-scrollbar { display: none; }

    body {
      align-items: stretch;
    }

    #app-shell {
      width: 100%;
      height: 100%;
      min-height: 100%;
      padding-top: var(--safe-top);
      padding-bottom: 0;
      display: flex;
      flex-direction: column;
      position: relative;
      overflow: hidden;
    }

    .neo-shell {
      position: relative;
      z-index: 2;
      width: min(432px, calc(100vw - 32px));
      height: min(884px, calc(100vh - 32px));
      min-height: 720px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.035), rgba(255,255,255,0.006) 24%, rgba(0,0,0,0.14)),
        rgba(3, 3, 4, 0.70);
      border-radius: var(--radius-shell);
      box-shadow:
        0 48px 140px rgba(0, 0, 0, 0.72),
        inset 0 0 0 1px rgba(255,255,255,0.045),
        inset 0 0 96px rgba(212, 20, 118, 0.025);
      overflow: hidden;
      isolation: isolate;
    }

    /* Mobile: full-screen, sem margens nem radius */
    @media (max-width: 520px) {
      .neo-shell {
        width: 100vw;
        height: 100dvh;
        min-height: 100dvh;
        border-radius: 0;
        box-shadow: none;
      }
      .neo-shell::before,
      .neo-shell::after { display: none; }
    }

    /* Borda incompleta: artefato, não card */
    .neo-shell::before,
    .neo-shell::after {
      content: "";
      position: absolute;
      pointer-events: none;
      z-index: 4;
    }

    .neo-shell::before {
      top: 0; left: 0;
      width: 72px; height: 1px;
      background: linear-gradient(90deg, rgba(212, 20, 118, 0.7), transparent);
      border-radius: var(--radius-shell) 0 0 0;
    }

    .neo-shell::after {
      top: 0; left: 0;
      width: 1px; height: 72px;
      background: linear-gradient(180deg, rgba(212, 20, 118, 0.7), transparent);
      border-radius: var(--radius-shell) 0 0 0;
    }

    /* Desktop background */
    .neo-chat-stage {
      position: relative;
      width: 100%;
      min-height: 100vh;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      background:
        radial-gradient(circle at 78% 6%, rgba(212, 20, 118, 0.20), transparent 26%),
        radial-gradient(circle at 12% 88%, rgba(95, 48, 128, 0.18), transparent 32%),
        linear-gradient(180deg, #08090b 0%, #050507 52%, #030304 100%);
    }

    .neo-chat-stage::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      background-image:
        linear-gradient(rgba(255, 255, 255, 0.020) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.014) 1px, transparent 1px);
      background-size: 44px 44px;
      -webkit-mask-image: linear-gradient(to bottom, black 0%, transparent 78%);
      mask-image: linear-gradient(to bottom, black 0%, transparent 78%);
    }

    .neo-chat-stage::after {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 1;
      opacity: 0.12;
      mix-blend-mode: soft-light;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.55'/%3E%3C/svg%3E");
      background-size: 180px 180px;
    }

    .chat-shell {
      position: relative;
      z-index: 2;
    }
  </style>

  <!-- Filtros de Processamento Visual -->
  <svg style="position: fixed; width: 0; height: 0; pointer-events: none;">
    <filter id="chromatic-aberration">
      <feOffset in="SourceGraphic" dx="-0.4" dy="0" result="red" />
      <feOffset in="SourceGraphic" dx="0.4" dy="0" result="blue" />
      <feComponentTransfer in="red" result="red-c">
        <feFuncR type="linear" slope="1" />
        <feFuncG type="linear" slope="0" />
        <feFuncB type="linear" slope="0" />
      </feComponentTransfer>
      <feComponentTransfer in="blue" result="blue-c">
        <feFuncR type="linear" slope="0" />
        <feFuncG type="linear" slope="0" />
        <feFuncB type="linear" slope="1" />
      </feComponentTransfer>
      <feBlend in="red-c" in2="blue-c" mode="screen" result="rb" />
      <feBlend in="rb" in2="SourceGraphic" mode="screen" />
    </filter>
  </svg>
  <!-- Cloudflare Web Analytics -->
  <script is:inline defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "abc85a5fe49144d391a3c0e6bc7608d7"}'></script>
</head>
<body>
    <script is:inline>
      document.body.classList.add('dark-mode');
    </script>
    <ClientRouter />
    <div class="neo-chat-stage">
      <div class="neo-shell">
        <main id="app-shell" class="chat-shell">
          <slot />
        </main>
      </div>
    </div>
    <script is:inline>
      if ("serviceWorker" in navigator && !["localhost", "127.0.0.1"].includes(location.hostname)) {
        window.addEventListener("load", () => {
          navigator.serviceWorker
            .register("/sw.js", { updateViaCache: "none" })
            .then((reg) => {
              reg.addEventListener("updatefound", () => {
                const next = reg.installing;
                next.addEventListener("statechange", () => {
                  if (next.state === "installed" && navigator.serviceWorker.controller) {
                    showUpdateBanner(reg);
                  }
                });
              });
            })
            .catch(() => {});
        });
      }

      function showUpdateBanner(reg) {
        if (document.getElementById("sw-update-banner")) return;
        const banner = document.createElement("div");
        banner.id = "sw-update-banner";
        banner.setAttribute("role", "status");
        banner.innerHTML =
          '<span>Nova versão disponível</span>' +
          '<button id="sw-update-btn" type="button">Atualizar</button>';
        Object.assign(banner.style, {
          position: "fixed",
          bottom: "calc(80px + env(safe-area-inset-bottom))",
          left: "50%",
          transform: "translateX(-50%)",
          zIndex: "9000",
          display: "flex",
          alignItems: "center",
          gap: "12px",
          padding: "10px 16px",
          borderRadius: "999px",
          background: "rgba(10,10,10,0.88)",
          backdropFilter: "blur(20px)",
          border: "1px solid rgba(255,7,124,0.35)",
          boxShadow: "0 4px 24px rgba(255,7,124,0.18)",
          fontFamily: "var(--font-mono, monospace)",
          fontSize: "12px",
          color: "#f0f0f0",
          whiteSpace: "nowrap",
          animation: "sw-banner-in 0.3s cubic-bezier(0.34,1.56,0.64,1) both",
        });
        const btn = banner.querySelector("#sw-update-btn");
        Object.assign(btn.style, {
          background: "#ff077c",
          color: "#fff",
          border: "none",
          borderRadius: "999px",
          padding: "5px 14px",
          fontSize: "12px",
          fontFamily: "inherit",
          fontWeight: "600",
          cursor: "pointer",
        });
        if (!document.getElementById("sw-banner-style")) {
          const s = document.createElement("style");
          s.id = "sw-banner-style";
          s.textContent = "@keyframes sw-banner-in{from{opacity:0;transform:translateX(-50%) translateY(12px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}";
          document.head.appendChild(s);
        }
        document.body.appendChild(banner);
        btn.addEventListener("click", () => {
          reg.waiting.postMessage({ type: "SKIP_WAITING" });
          navigator.serviceWorker.addEventListener("controllerchange", () => location.reload());
          banner.remove();
        });
      }

      let viewportRaf = 0;

      function setViewportHeight() {
        const vh = window.innerHeight * 0.01;
        document.documentElement.style.setProperty("--vh", `${vh}px`);
      }

      function syncViewportHeight() {
        cancelAnimationFrame(viewportRaf);
        viewportRaf = requestAnimationFrame(() => {
          const vv = window.visualViewport;
          const height = vv ? vv.height : window.innerHeight;
          document.documentElement.style.setProperty("--app-height", `${height}px`);
        });
      }

      function syncKeyboardInset() {
        const inputArea = document.querySelector(".input-area");
        if (!inputArea) return;
        const vv = window.visualViewport;
        if (!vv) {
          inputArea.style.paddingBottom = "";
          return;
        }

        const keyboardHeight = window.innerHeight - vv.height;
        if (keyboardHeight > 100) {
          inputArea.style.paddingBottom = `${keyboardHeight + 20}px`;
        } else {
          inputArea.style.paddingBottom = "";
        }
      }

      setViewportHeight();
      syncViewportHeight();
      syncKeyboardInset();

      if (window.visualViewport) {
        window.visualViewport.addEventListener("resize", syncViewportHeight);
        window.visualViewport.addEventListener("scroll", syncViewportHeight);
        window.visualViewport.addEventListener("resize", syncKeyboardInset);
        window.visualViewport.addEventListener("scroll", syncKeyboardInset);
      }
      window.addEventListener("resize", () => {
        setViewportHeight();
        syncViewportHeight();
        syncKeyboardInset();
      });
    </script>
</body>
</html>
