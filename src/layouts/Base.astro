  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Codystar&family=Geist+Mono:wght@300;400;500&family=Inter+Tight:wght@500;600;700&display=swap" rel="stylesheet" />

  <style is:global>
    :root {
      --bg:          #f0f4f8;
      --bg-alt:      #e2e8f0;
      --surface:     rgba(0, 0, 0, 0.04) !important;
      --surface-dark:rgba(0, 0, 0, 0.08) !important;
      --hud:         rgba(0, 0, 0, 0.06) !important;
      --hud-soft:    rgba(0, 0, 0, 0.02) !important;
      --border:      rgba(0, 0, 0, 0.05) !important;
      --border-hud:  rgba(255, 255, 255, 0.25) !important;
      --glass-blur:  blur(25px) saturate(1.5) !important;
      --glass-shadow: 0 4px 16px rgba(0, 0, 0, 0.03), inset 0 1px 0.5px rgba(255, 255, 255, 0.4), inset 0 -1px 2px rgba(0, 0, 0, 0.01) !important;
      
      --neon-pink:  #ff077c;
      --neon-pink-dim: rgba(255, 7, 124, 0.15);
      --neon-glow:   rgba(255, 7, 124, 0.4);
      --neon-glow-intense: rgba(255, 7, 124, 0.6);
      
      --neon-pink-secondary:   #ff077c;
      --neon-pink-dim-secondary: rgba(255, 7, 124, 0.15);
      
      --text-primary:#1a1c1e;
      --text-muted:  #5c6e7a;
      --text-hud:    #1a1c1e;
      --text-hud-dim:#7e8c9a;
      
      --radius-card: 24px;
      --radius-pill: 999px;
      
      --shadow-card: 0 4px 20px rgba(0, 0, 0, 0.03);
      --shadow-hud:  0 8px 32px rgba(0, 0, 0, 0.05);
      --shadow-inner: inset 0 1px 4px rgba(0,0,0,0.02);
      --glow-soft: 0 0 20px rgba(255, 7, 124, 0.1);
      
      --font-display:'Inter Tight', sans-serif;
      --font-mono:   'Geist Mono', monospace;
      --font-dot:    'Codystar', sans-serif;
      
      --safe-top:    env(safe-area-inset-top, 0px);
      --safe-bottom: env(safe-area-inset-bottom, 0px);
    }

    body.dark-mode {
      --bg: #0a0a0a;
      --bg-alt: #000000;
      --surface: rgba(0, 0, 0, 0.7);
      --surface-dark: rgba(0, 0, 0, 0.85);
      --hud: rgba(0, 0, 0, 0.75);
      --hud-soft: rgba(0, 0, 0, 0.5);
      --text-primary: #ffffff;
      --text-muted: #888888;
      --border: rgba(255, 255, 255, 0.15);
      --border-hud: rgba(255, 255, 255, 0.1);
      --glass-blur: blur(35px) saturate(1.4) brightness(0.8);
      --glass-shadow: 0 12px 40px rgba(0, 0, 0, 0.95), inset 0 1px 0 rgba(255, 255, 255, 0.15);
      --shadow-card: var(--glass-shadow);
      --shadow-inner: inset 0 4px 12px rgba(0, 0, 0, 0.8);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; height: 100dvh; overflow: hidden; -webkit-tap-highlight-color: transparent; }

    body {
      font-family: var(--font-mono);
      background: radial-gradient(circle at center, var(--bg) 0%, var(--bg-alt) 100%);
      background-attachment: fixed;
      color: var(--text-primary);
      display: flex;
      flex-direction: column;
      /* Safe Areas para PWA Mobile */
      padding-top: var(--safe-top);
      padding-bottom: var(--safe-bottom);
    }

    body::before {
      content: '';
      position: fixed; inset: 0;
      opacity: 0.055; pointer-events: none; z-index: 9999;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-repeat: repeat; background-size: 180px;
    }
    
    * { scrollbar-width: none; }
    *::-webkit-scrollbar { display: none; }
  </style>
</head>
<body>
    <slot />
</body>
</html>
