---
// src/components/ChatBubble.astro
interface Props {
  role: 'user' | 'agent';
  content: string;
  time: string;
}

const { role, content, time } = Astro.props;
const isUser = role === 'user';
---

<div class={`msg-container ${isUser ? 'user-side' : 'agent-side'}`}>
  <div class="bubble-wrapper">
    {!isUser && <span class="label">NEØ:One</span>}
    {isUser && <span class="label visitor-label">VISITANTE: %------</span>}
    
    <div class="bubble">
      {content}
    </div>
    
    <span class="timestamp">{time}</span>
  </div>
</div>

<style>
  .msg-container {
    display: flex;
    width: 100%;
    margin-bottom: 16px;
  }

  .user-side { justify-content: flex-end; }
  .agent-side { justify-content: flex-start; }

  .bubble-wrapper {
    max-width: 82%;
    display: flex;
    flex-direction: column;
  }

  .user-side .bubble-wrapper { align-items: flex-end; }
  .agent-side .bubble-wrapper { align-items: flex-start; }

  .label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.08em;
    margin-bottom: 5px;
    text-transform: uppercase;
  }

  .user-side .label { color: var(--neon-pink); opacity: 0.7; text-align: right; }
  .agent-side .label { color: var(--neon-green); opacity: 0.7; text-align: left; }

  .bubble {
    padding: 14px 17px;
    font-size: 15px;
    line-height: 1.6;
    white-space: pre-wrap;
    position: relative;
    overflow: hidden;
    box-shadow:
      inset 0 0 42px rgba(255, 255, 255, 0.014),
      0 22px 52px rgba(0, 0, 0, 0.18);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    transition: background 0.3s ease;
  }

  .bubble::before,
  .bubble::after {
    content: "";
    position: absolute;
    width: 30px;
    height: 30px;
    pointer-events: none;
  }

  /* BALÃO DO AGENTE */
  .agent-side .bubble {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.032), rgba(255, 255, 255, 0.012)),
      var(--surface);
    color: var(--text-hud);
    border: 1px solid rgba(255, 255, 255, 0.082);
    border-radius: 3px 16px 16px 16px;
  }

  .agent-side .bubble::before {
    top: -1px;
    left: -1px;
    border-top: 1px solid rgba(255, 7, 124, 0.50);
    border-left: 1px solid rgba(255, 7, 124, 0.50);
    box-shadow: -10px -10px 36px rgba(255, 7, 124, 0.08);
  }

  .agent-side .bubble::after {
    right: -1px;
    bottom: -1px;
    border-right: 1px solid rgba(255, 255, 255, 0.10);
    border-bottom: 1px solid rgba(255, 255, 255, 0.10);
  }

  /* BALÃO DO USUÁRIO */
  .user-side .bubble {
    background: rgba(255, 255, 255, 0.026);
    color: var(--text-hud);
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 13px 3px 13px 13px;
    text-align: right;
    box-shadow:
      inset 0 0 36px rgba(255, 255, 255, 0.012),
      0 16px 42px rgba(0, 0, 0, 0.16);
  }

  .user-side .bubble::before {
    top: -1px;
    right: -1px;
    border-top: 1px solid rgba(255, 255, 255, 0.16);
    border-right: 1px solid rgba(255, 255, 255, 0.16);
  }

  .user-side .bubble::after {
    left: -1px;
    bottom: -1px;
    border-left: 1px solid rgba(255, 7, 124, 0.28);
    border-bottom: 1px solid rgba(255, 7, 124, 0.28);
    box-shadow: -8px 8px 28px rgba(255, 7, 124, 0.06);
  }

  .timestamp {
    font-family: var(--font-mono);
    font-size: 11px;
    margin-top: 5px;
    color: var(--text-muted);
    opacity: 0.72;
    letter-spacing: 0.05em;
  }

  .user-side .timestamp { text-align: right; }
  .agent-side .timestamp { text-align: left; }

  .bubble :global(p) { margin: 0; }
  .bubble :global(p + p) { margin-top: 8px; }
</style>
