---
// src/components/ChatBubble.astro
interface Props {
  role: 'user' | 'agent';
  content: string;
  time: string;
}

const { role, content, time } = Astro.props;
const isUser = role === 'user';
---

<div class={`msg-container ${isUser ? 'user-side' : 'agent-side'}`}>
  <div class="bubble-wrapper">
    {!isUser && <span class="label">NEØ:One</span>}
    {isUser && <span class="label visitor-label">VISITANTE: %------</span>}
    
    <div class="bubble">
      {content}
    </div>
    
    <span class="timestamp">{time}</span>
  </div>
</div>

<style>
  .msg-container {
    display: flex;
    width: 100%;
    margin-bottom: 16px;
    animation: bubbleIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes bubbleIn {
    from { opacity: 0; transform: translateY(10px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .user-side { justify-content: flex-end; }
  .agent-side { justify-content: flex-start; }

  .bubble-wrapper {
    max-width: 82%;
    display: flex;
    flex-direction: column;
  }

  .user-side .bubble-wrapper { align-items: flex-end; }
  .agent-side .bubble-wrapper { align-items: flex-start; }

  .label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.08em;
    margin-bottom: 5px;
    text-transform: uppercase;
  }

  .user-side .label { color: var(--neon-pink); opacity: 0.7; text-align: right; }
  .agent-side .label { color: var(--neon-green); opacity: 0.7; text-align: left; }

  body:not(.dark-mode) .label {
    color: rgba(46, 0, 23, 0.74);
    opacity: 1;
  }

  .bubble {
    padding: 12px 16px;
    font-size: 15px;
    line-height: 1.6;
    white-space: pre-wrap;
    position: relative;
    box-shadow: var(--glass-shadow);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    transition: background 0.3s ease;
  }

  /* BALÃO DO AGENTE */
  .agent-side .bubble {
    background: var(--surface);
    color: var(--text-hud);
    border: 1px solid var(--border-hud);
    border-radius: 2px 20px 20px 20px;
    border-left: 2px solid rgba(244, 244, 244, 0.45);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
  }

  body:not(.dark-mode) .agent-side .bubble {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.91), rgba(255, 235, 245, 0.86));
    color: #2a0617;
    border-color: rgba(255, 255, 255, 0.62);
    border-left-color: rgba(255, 7, 124, 0.72);
    box-shadow: 0 14px 34px rgba(104, 0, 47, 0.24), inset 0 1px 0 rgba(255, 255, 255, 0.7);
  }

  /* BALÃO DO USUÁRIO */
  .user-side .bubble {
    background: var(--hud-soft);
    color: var(--text-hud);
    border: 1px solid var(--border-hud);
    border-radius: 20px 2px 20px 20px;
    border-right: 2px solid rgba(93, 92, 92, 0.959);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
  }

  body:not(.dark-mode) .user-side .bubble {
    background: rgba(83, 0, 40, 0.84);
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.38);
    border-right-color: rgba(255, 255, 255, 0.74);
    box-shadow: 0 10px 26px rgba(80, 0, 39, 0.22);
  }

  .timestamp {
    font-family: var(--font-mono);
    font-size: 9px;
    margin-top: 5px;
    color: var(--text-muted);
    opacity: 0.72;
    letter-spacing: 0.05em;
  }

  body:not(.dark-mode) .timestamp {
    color: rgba(46, 0, 23, 0.68);
    opacity: 1;
  }

  .user-side .timestamp { text-align: right; }
  .agent-side .timestamp { text-align: left; }
</style>
