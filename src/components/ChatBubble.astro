---
// src/components/ChatBubble.astro
interface Props {
  role: 'user' | 'agent';
  content: string;
  time: string;
}

const { role, content, time } = Astro.props;
const isUser = role === 'user';
---

<div class={`msg-container ${isUser ? 'user-side' : 'agent-side'}`}>
  <div class="bubble-wrapper">
    {!isUser && <span class="label">NEØ:One</span>}
    {isUser && <span class="label">Visitante: %100110</span>}
    
    <div class="bubble">
      {content}
    </div>
    
    <span class="timestamp">{time}</span>
  </div>
</div>

<style>
  .msg-container {
    display: flex;
    width: 100%;
    margin-bottom: 16px;
    animation: bubbleIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes bubbleIn {
    from { opacity: 0; transform: translateY(10px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .user-side { justify-content: flex-end; }
  .agent-side { justify-content: flex-start; }

  .bubble-wrapper {
    max-width: 82%;
    display: flex;
    flex-direction: column;
  }

  .user-side .bubble-wrapper { align-items: flex-end; }
  .agent-side .bubble-wrapper { align-items: flex-start; }

  .label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.08em;
    margin-bottom: 5px;
    text-transform: uppercase;
  }

  .user-side .label { color: var(--neon-pink); text-align: right; }
  .agent-side .label { color: var(--neon-green); text-align: left; }

  .bubble {
    padding: 12px 16px;
    font-size: 15px;
    line-height: 1.6;
    white-space: pre-wrap;
    position: relative;
    box-shadow: var(--glass-shadow);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    transition: background 0.3s ease;
  }

  /* BALÃO DO AGENTE (Esquerda - Cristalino/Acqua) */
  .agent-side .bubble {
    background: var(--surface);
    color: var(--text-hud);
    border: 1px solid var(--border-hud);
    border-radius: 2px 20px 20px 20px;
    border-left: 2px solid rgba(255, 7, 124, 1);
    box-shadow: 
      0 10px 30px rgba(0,0,0,0.08),
      -2px 0 8px rgba(255, 255, 255, 0.4), /* Luz Branca Neutra */
      2px 0 8px rgba(255, 7, 124, 0.4);   /* Magenta da Marca */
  }

  .agent-side .bubble::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.22) 0%,
      rgba(255, 255, 255, 0.08) 45%,
      rgba(255, 7, 124, 0.08) 100%
    ); pointer-events: none;
    border-radius: inherit;
  }

  /* BALÃO DO USUÁRIO (Direita - Glass Deep) */
  .user-side .bubble {
    background: var(--hud-soft);
    color: var(--text-hud);
    border: 1px solid var(--border-hud);
    border-radius: 20px 2px 20px 20px;
    border-right: 2px solid rgba(255, 7, 124, 1);
    box-shadow: 
      0 10px 30px rgba(0,0,0,0.08),
      2px 0 8px rgba(255, 255, 255, 0.4),
      -2px 0 8px rgba(255, 7, 124, 0.4);
  }

  .timestamp {
    font-family: var(--font-mono);
    font-size: 9px;
    margin-top: 5px;
    color: var(--text-muted);
    opacity: 0.72;
    letter-spacing: 0.05em;
  }

  .user-side .timestamp { text-align: right; }
  .agent-side .timestamp { text-align: left; }
</style>
