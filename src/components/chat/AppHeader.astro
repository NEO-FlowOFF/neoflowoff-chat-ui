---
import { Image } from 'astro:assets';
---

<header class="header" transition:name="chat-header" transition:persist>
  <div class="agent-pill">
    <div class="agent-avatar">
      <Image src="https://res.cloudinary.com/dgyocpguk/image/upload/v1769091295/flowoff/public/icon-512.webp" alt="NEØ FlowOFF" width={44} height={44} loading="eager" />
    </div>
    <div class="agent-info">
      <span class="agent-name">NEØ FlowOFF</span>
      <span class="agent-status">online</span>
    </div>
  </div>
  <div class="header-actions">
    <button type="button" class="theme-switch" id="themeToggle" aria-label="Alternar tema" aria-pressed="false">
      <span class="theme-ring" aria-hidden="true"></span>
      <svg class="sun-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M22 12h2"/><path d="m4.93 19.07 1.41-1.41"/><path d="m17.66 6.34 1.41-1.41"/></svg>
      <svg class="moon-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
    </button>
    <button class="icon-btn" id="clearBtn" aria-label="Limpar conversa">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 12a9 9 0 1 0 3-6.7"/><path d="M3 3v4h4"/>
      </svg>
    </button>
  </div>
</header>
