---
import Base from "../layouts/Base.astro";
---

<Base>
  <main class="splash" aria-label="Carregando">
    <div class="splash-card">
      <div class="logo-wrap" aria-hidden="true">
        <img
          src="https://res.cloudinary.com/dgyocpguk/image/upload/v1769091295/flowoff/public/icon-512.webp"
          alt=""
          width="74"
          height="74"
          loading="eager"
          decoding="async"
        />
      </div>

      <p class="splash-text" aria-live="polite">
        Você já vai ser atendido pelo assistente oficial da NEØ FlowOFF
      </p>

      <div
        class="splash-loader"
        role="status"
        aria-label="Carregando"
        aria-hidden="true"
      >
        <span></span><span></span><span></span>
      </div>
    </div>
  </main>

  <style>
    :root {
      --splash-delay: 5200ms;
      --splash-fade-out: 260ms;
    }

    .splash {
      min-height: 100dvh;
      display: grid;
      place-items: center;
      padding: 24px;
      animation: fade-in 0.35s ease both;
      transition: opacity var(--splash-fade-out) ease;
    }

    .splash.is-leaving {
      opacity: 0;
    }

    .splash-card {
      width: min(640px, 100%);
      padding: 18px 10px;
      display: grid;
      justify-items: center;
      gap: 20px;
      text-align: center;
    }

    .logo-wrap img {
      display: block;
      filter: drop-shadow(0 8px 18px rgba(0, 0, 0, 0.16));
      animation: pop-in 0.45s cubic-bezier(0.18, 0.8, 0.25, 1) 0.06s both;
    }

    .splash-text {
      font-family: var(--font-mono);
      color: var(--text-primary);
      font-size: clamp(18px, 2.35vw, 26px);
      line-height: 1.45;
      letter-spacing: 0.02em;
      font-weight: 600;
      max-width: 30ch;
      margin: 0;
      text-wrap: balance;
      text-shadow: 0 2px 18px rgba(0,0,0,0.10);
      animation: pop-in 0.45s cubic-bezier(0.18, 0.8, 0.25, 1) 0.14s both;
    }

    .splash-loader {
      display: inline-flex;
      gap: 7px;
      align-items: center;
      margin-top: 2px;
      animation: pop-in 0.45s cubic-bezier(0.18, 0.8, 0.25, 1) 0.2s both;
    }

    .splash-loader span {
      width: 7px;
      height: 7px;
      border-radius: 999px;
      background: var(--neon-pink);
      box-shadow: 0 0 10px rgba(255, 7, 124, 0.35);
      animation: pulse 1.1s ease-in-out infinite;
    }

    .splash-loader span:nth-child(2) {
      animation-delay: 0.15s;
      opacity: 0.85;
    }

    .splash-loader span:nth-child(3) {
      animation-delay: 0.3s;
      opacity: 0.7;
    }

    @keyframes pulse {
      0%,
      80%,
      100% {
        transform: translateY(0);
        opacity: 0.35;
      }
      40% {
        transform: translateY(-3px);
        opacity: 1;
      }
    }

    @keyframes pop-in {
      from {
        opacity: 0;
        transform: translateY(10px) scale(0.98);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    @keyframes fade-in {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }

    /* Respeita preferência do sistema por menos movimento */
    @media (prefers-reduced-motion: reduce) {
      .splash,
      .logo-wrap img,
      .splash-text,
      .splash-loader,
      .splash-loader span {
        animation: none !important;
        transition: none !important;
      }
    }
  </style>

  <script>
    const REDIRECT_DELAY = 5200;
    const FADE_DURATION = 260;

    window.setTimeout(() => {
      try {
        sessionStorage.setItem("nox_intro_seen", "1");
      } catch {
        // sessionStorage pode estar bloqueado (modo privado restrito)
      }

      const splash = document.querySelector(".splash");

      if (
        splash &&
        !window.matchMedia("(prefers-reduced-motion: reduce)").matches
      ) {
        splash.classList.add("is-leaving");
        window.setTimeout(
          () => window.location.replace("/chat"),
          FADE_DURATION
        );
      } else {
        window.location.replace("/chat");
      }
    }, REDIRECT_DELAY);
  </script>
</Base>
