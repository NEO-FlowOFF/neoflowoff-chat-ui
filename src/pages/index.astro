---
import Base from "../layouts/Base.astro";
---

<Base>
  <main class="splash" aria-label="Carregando">

    <!-- Fallback CSS — sempre renderiza, vídeo sobrepõe se carregar -->
    <div class="scan-stage" id="cssFallback">
      <div class="scan-line" aria-hidden="true"></div>
      <p class="brand-name">neoflowoff.agency</p>
    </div>
    <span class="idle-dot" id="cssDot" aria-hidden="true"></span>

    <!-- Vídeo — z-index acima do fallback -->
    <video
      id="splashVideo"
      class="splash-video"
      autoplay
      muted
      playsinline
      preload="auto"
      aria-hidden="true"
    >
      <source
        src="/splash_chat.mp4"
        type="video/mp4"
      />
    </video>

  </main>

  <style>
    .splash {
      width: 100%;
      height: 100dvh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 18px;
      background: #111111;
      animation: fade-in 0.3s ease both;
      transition: opacity 260ms ease;
      position: relative;
      overflow: hidden;
    }

    .splash.is-leaving { opacity: 0; }

    /* ── Vídeo ─────────────────────────────────── */
    .splash-video {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      z-index: 2;
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .splash-video.is-playing { opacity: 1; }

    /* ── Fallback CSS ───────────────────────────── */
    .scan-stage {
      position: relative;
      display: inline-block;
      z-index: 1;
    }

    .scan-line {
      position: absolute;
      top: 50%;
      left: -4px;
      width: 1px;
      height: 220%;
      transform: translateY(-50%);
      background: linear-gradient(
        to bottom,
        transparent,
        #ff077c 35%,
        #ff077c 65%,
        transparent
      );
      box-shadow: 0 0 10px rgba(255, 7, 124, 0.8), 0 0 2px #ff077c;
      animation: line-sweep 0.8s cubic-bezier(0.4, 0, 0.4, 1) 0.35s both;
    }

    @keyframes line-sweep {
      from { left: -4px; }
      to   { left: calc(100% + 4px); }
    }

    .brand-name {
      font-family: var(--font-display);
      font-size: 15px;
      font-weight: 500;
      color: #ffffff;
      letter-spacing: -0.015em;
      margin: 0;
      white-space: nowrap;
      clip-path: inset(0 100% 0 0);
      animation: text-reveal 0.8s cubic-bezier(0.4, 0, 0.4, 1) 0.35s both;
    }

    @keyframes text-reveal {
      from { clip-path: inset(0 100% 0 0); }
      to   { clip-path: inset(0 0% 0 0); }
    }

    .idle-dot {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--neon-orange, #ff6d00);
      box-shadow: 0 0 6px rgba(255, 109, 0, 0.55);
      opacity: 0;
      z-index: 1;
      animation:
        dot-in    0.3s ease 1.3s both,
        dot-pulse 2s ease-in-out 1.6s infinite;
    }

    @keyframes dot-in {
      from { opacity: 0; transform: scale(0.4); }
      to   { opacity: 1; transform: scale(1); }
    }

    @keyframes dot-pulse {
      0%, 100% { opacity: 1;   transform: scale(1); }
      50%      { opacity: 0.4; transform: scale(0.75); }
    }

    @keyframes fade-in {
      from { opacity: 0; }
      to   { opacity: 1; }
    }

    @media (prefers-reduced-motion: reduce) {
      .splash, .scan-line, .brand-name, .idle-dot, .splash-video {
        animation: none !important;
        transition: none !important;
      }
      .brand-name  { clip-path: none; }
      .splash-video { display: none; }
    }
  </style>

  <script>
    const video   = document.getElementById("splashVideo") as HTMLVideoElement | null;
    const splash  = document.querySelector(".splash");
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    function redirect() {
      if (splash && !reduced) {
        splash.classList.add("is-leaving");
        setTimeout(() => window.location.replace("/chat"), 260);
      } else {
        window.location.replace("/chat");
      }
    }

    try { sessionStorage.setItem("flow_intro_seen", "1"); } catch {}

    const MIN_MS   = 2500; // tempo mínimo de exibição
    const startAt  = Date.now();

    function redirectAfterMin() {
      const elapsed   = Date.now() - startAt;
      const remaining = Math.max(0, MIN_MS - elapsed);
      setTimeout(redirect, remaining);
    }

    if (video && !reduced) {
      const safety = setTimeout(redirect, 8000);

      video.addEventListener("canplay", () => {
        video.classList.add("is-playing");
      });

      video.addEventListener("ended", () => {
        clearTimeout(safety);
        redirectAfterMin(); // garante mínimo mesmo se vídeo for curto
      });

      video.addEventListener("error", () => {
        clearTimeout(safety);
        setTimeout(redirect, 3500); // CSS fallback assume por 3.5s
      });

      // Se não começar em 3s, assume que falhou
      setTimeout(() => {
        if (video.readyState < 2) video.dispatchEvent(new Event("error"));
      }, 3000);

    } else {
      setTimeout(redirect, 3500);
    }
  </script>
</Base>
