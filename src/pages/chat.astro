---
import Base from '@/layouts/Base.astro';
import ChatBubble from '@/components/ChatBubble.astro';
import AppHeader from '@/components/chat/AppHeader.astro';
import EmptyState from '@/components/chat/EmptyState.astro';
import Composer from '@/components/chat/Composer.astro';
import InstallBanner from '@/components/chat/InstallBanner.astro';
---

<Base>
  <AppHeader />

  <div id="templates" style="display: none;">
    <div id="tpl-user"><ChatBubble role="user" content="{{CONTENT}}" time="{{TIME}}" /></div>
    <div id="tpl-agent"><ChatBubble role="agent" content="{{CONTENT}}" time="{{TIME}}" /></div>
  </div>

  <div class="messages-wrap" id="messagesWrap" transition:name="chat-messages">
    <EmptyState />
  </div>

  <InstallBanner />
  <Composer />
  <div class="toast" id="toast"></div>

  <div id="confirm-backdrop" class="confirm-backdrop" hidden>
    <div class="confirm-box" role="alertdialog" aria-modal="true" aria-labelledby="confirm-msg">
      <p id="confirm-msg" class="confirm-msg"></p>
      <div class="confirm-actions">
        <button id="confirm-cancel" class="confirm-btn confirm-btn--cancel" type="button">Cancelar</button>
        <button id="confirm-ok" class="confirm-btn confirm-btn--ok" type="button">Confirmar</button>
      </div>
    </div>
  </div>

  <style>
    .confirm-backdrop {
      position: absolute;
      inset: 0;
      z-index: 500;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(0, 0, 0, 0.28);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
      padding: 24px;
      animation: fade-in 0.15s ease both;
    }
    .confirm-backdrop[hidden] { display: none; }

    .confirm-box {
      background: var(--hud);
      border: 1px solid var(--border-hud);
      border-radius: 16px;
      box-shadow: var(--glass-shadow);
      padding: 16px 18px;
      width: 100%;
      max-width: 280px;
      display: flex;
      flex-direction: column;
      gap: 14px;
      animation: pop-up 0.2s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    .confirm-msg {
      font-family: var(--font-mono);
      font-size: 13px;
      color: var(--text-primary);
      line-height: 1.5;
      margin: 0;
    }

    .confirm-actions {
      display: flex;
      gap: 8px;
      justify-content: flex-end;
    }

    .confirm-btn {
      font-family: var(--font-display);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: -0.01em;
      padding: 7px 16px;
      border-radius: 999px;
      border: none;
      cursor: pointer;
      transition: opacity 0.15s;
    }
    .confirm-btn:active { opacity: 0.75; }

    .confirm-btn--cancel {
      background: transparent;
      color: var(--text-muted);
      border: 1px solid var(--border);
    }
    .confirm-btn--ok {
      background: var(--neon-pink);
      color: #fff;
      box-shadow: 0 2px 10px rgba(255, 7, 124, 0.3);
    }

    @keyframes pop-up {
      from { opacity: 0; transform: scale(0.94) translateY(6px); }
      to   { opacity: 1; transform: scale(1) translateY(0); }
    }
  </style>

  <script src="../scripts/chat-ui.ts"></script>
</Base>
